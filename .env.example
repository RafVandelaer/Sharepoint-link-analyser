# SharePoint Link Analyzer - Environment Configuration
# Copy this file to .env and fill in your values

# Node environment: 'development' or 'production'
NODE_ENV=production

# Server port
PORT=3000

# JWT secret for signing admin tokens (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_random_jwt_secret_here_min_32_chars

# Admin password hash using bcrypt (generate: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-secure-password', 10).then(h => console.log(h));")
# Example: $2b$10$... (starts with $2b$10$)
ADMIN_PASSWORD_HASH=$2b$10$your_bcrypt_hash_here

# Allowed origins for CORS (comma-separated)
# Example: http://localhost:3000,https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Logging level: 'error', 'warn', 'info', 'debug'
LOG_LEVEL=info

# Session configuration
SESSION_MAX_AGE=3600000

# Rate limiting: max requests per window
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_ANALYTICS_MAX=100
